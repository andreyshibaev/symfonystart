{% extends 'base.html.twig' %}

{% block title %}
{{ title }} - {{ app.user.email}}
{% endblock %}

{% block body %}
<div class="container">
{% for message in app.flashes('success') %}
    <div class="alert alert-success">
        {{ message }}
    </div>
{% endfor %}
    <h1>Hello {{ app.user.email}}</h1>
</div>
{% endblock %}
